// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("SALES")
  leads     Lead[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id                String       @id @default(cuid())
  clientName        String
  companyName       String?
  phone             String
  email             String
  serviceInterested String?
  dealValue         Float?
  notes             String?
  assignedTo        String
  assignedUser      User         @relation(fields: [assignedTo], references: [id])
  stage             String       @default("FIND_LEADS")
  dateCreated       DateTime     @default(now())
  activities        Activity[]
  commission        Commission?
  stageData         StageData[]
  updatedAt         DateTime     @updatedAt
}

model Activity {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        String
  description String
  date        DateTime @default(now())
}

model Commission {
  id       String  @id @default(cuid())
  leadId   String  @unique
  lead     Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  amount   Float
  rate     Float
  earned   Float
  status   String  @default("PENDING")
  createdAt DateTime @default(now())
}

model StageData {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  stage     String
  data      String   // JSON string containing stage-specific data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leadId, stage])
}
